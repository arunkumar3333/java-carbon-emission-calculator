<?xml version="1.0" encoding="UTF-8"?>

<hibernate-configuration>

    <session-factory>

        <!-- MySQL Driver -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        

        <!-- Database URL -->
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/carbon_tracker</property>

        <!-- Database Username -->
        <property name="hibernate.connection.username">root</property>

        <!-- Database Password -->
        <property name="hibernate.connection.password">Root@123</property>

        <!-- Hibernate Dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <!-- Show SQL -->
        <property name="hibernate.show_sql">true</property>

        <!-- Entity Mapping -->
        <mapping class="com.carbontracker.entity.User"/>
        <mapping class="com.carbontracker.entity.Activity"/>
        <mapping class="com.carbontracker.entity.CarbonRecord"/>

    </session-factory>

</hibernate-configuration>


